<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    {{ page_title }}
    {%- unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}
  </title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}" />
  {% endif %}
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" /></noscript>
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <style>
    html, body { width: 100%; min-height: 100vh; overflow-x: hidden; }
    body { display: flex; flex-direction: column; }
    main { flex: 1; }

    #un-videobg {
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      z-index: -2;
      overflow: hidden;
    }
    #un-videobg video {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%) scale(1.15);
      min-width: 100%; min-height: 100%;
      width: auto; height: auto;
      object-fit: cover;
      filter: saturate(0.4) brightness(0.35);
    }
    #un-videobg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(8,11,8,0.4) 0%, rgba(8,11,8,0.2) 50%, rgba(8,11,8,0.7) 100%);
    }
  </style>
</head>
<body>
  <div id="un-videobg">
    <video id="bg-video" muted loop playsinline>
    </video>
  </div>
  <script>
    // Načti video až po načtení stránky
    window.addEventListener('load', function() {
      var video = document.getElementById('bg-video');
      var source = document.createElement('source');
      source.src = 'https://cdn.shopify.com/videos/c/o/v/0a05ebd7b50b4986b0824e28f5d275c8.mp4';
      source.type = 'video/mp4';
      video.appendChild(source);
      video.load();
      video.play().catch(function(){});
    });
  </script>

  {% section 'header' %}
  <main>{{ content_for_layout }}</main>
  {% section 'footer' %}

  {{ 'main.js' | asset_url | script_tag }}
  <script>
    // Ztmav video na specifickych strankach
    var path = window.location.pathname;
    if (path.indexOf('/pages/') !== -1 || path.indexOf('/products/') !== -1) {
      var vid = document.querySelector('#un-videobg video');
      if (vid) vid.style.filter = 'saturate(0.3) brightness(0.2)';
    }
  </script>
</body>
</html>
