<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    {{ page_title }}
    {%- unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}
  </title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}" />
  {% endif %}
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" /></noscript>
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <style>
    html, body { width: 100%; min-height: 100%; overflow-x: hidden; }
    body { display: flex; flex-direction: column; }
    main { flex: 1; }

    /* Fixní pozadí — desktop */
    body::after {
      content: '';
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background-image: url('https://cdn.shopify.com/s/files/1/1029/3008/8276/files/video.png?v=1777579166');
      background-size: cover;
      background-position: center;
      background-color: #0D110D;
      z-index: -2;
    }
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(8,11,8,0.82);
      z-index: -1;
      pointer-events: none;
    }

    /* iOS Safari fix — pseudo-element na html */
    @supports (-webkit-touch-callout: none) {
      body::after {
        position: fixed;
        -webkit-transform: translateZ(0);
        transform: translateZ(0);
      }
    }
  </style>
</head>
<body>
  {% section 'header' %}
  <main>{{ content_for_layout }}</main>
  {% section 'footer' %}
  {{ 'main.js' | asset_url | script_tag }}
</body>
</html>
