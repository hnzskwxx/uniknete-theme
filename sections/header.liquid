<style>
.un-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 48px;
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 9000;
  background: transparent;
  transition: background 0.3s;
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
}
.un-nav.scrolled {
  background: rgba(13,17,13,0.97);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
}
.un-logo {
  font-family: 'Syne', sans-serif;
  font-size: 18px; font-weight: 800;
  color: var(--white);
  letter-spacing: 2px; text-transform: uppercase; text-decoration: none;
  position: relative; z-index: 9002;
}
.un-logo span { color: var(--accent); }

.nav-links {
  display: flex; gap: 40px;
  list-style: none; align-items: center;
}
.nav-links a {
  color: var(--white);
  text-decoration: none;
  font-size: 12px; font-weight: 500;
  letter-spacing: 1px; text-transform: uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--accent); }

.nav-toggle {
  display: none;
  background: none; border: none;
  cursor: pointer;
  padding: 10px;
  position: relative; z-index: 9002;
  -webkit-tap-highlight-color: transparent;
}
.nav-toggle-bar {
  display: block; width: 24px; height: 2px;
  background: var(--white); border-radius: 2px;
  margin: 5px 0;
  transition: all 0.3s;
}

.nav-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(8,11,8,0.98);
  z-index: 8999;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 32px;
}
.nav-overlay.open { display: flex; }
.nav-overlay a {
  color: var(--white);
  text-decoration: none;
  font-size: 20px; font-weight: 500;
  letter-spacing: 2px; text-transform: uppercase;
  -webkit-tap-highlight-color: transparent;
}
.nav-overlay a:active { color: var(--accent); }

@media (max-width: 900px) {
  .un-nav { padding: 16px 24px; }
  .nav-toggle { display: block; }
  .nav-links { display: none; }
}
</style>

<nav class="un-nav" id="un-nav">
  <a href="/" class="un-logo">Unikněte<span>!</span></a>

  <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Menu">
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
  </button>

  <ul class="nav-links">
    {% for link in linklists[section.settings.menu].links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
    {% endfor %}
  </ul>
</nav>

<!-- Mobilní overlay menu — separátní od nav -->
<div class="nav-overlay" id="nav-overlay">
  {% for link in linklists[section.settings.menu].links %}
    <a href="{{ link.url }}">{{ link.title }}</a>
  {% endfor %}
</div>

<script>
(function() {
  var toggle = document.getElementById('nav-toggle');
  var overlay = document.getElementById('nav-overlay');
  var nav = document.getElementById('un-nav');

  if (!toggle || !overlay) return;

  toggle.addEventListener('click', function() {
    overlay.classList.toggle('open');
  });

  overlay.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() {
      overlay.classList.remove('open');
    });
  });

  window.addEventListener('scroll', function() {
    if (window.scrollY > 40) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
