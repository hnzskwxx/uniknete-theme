<style>
.un-footer {
  padding: 40px 48px;
  background: rgba(8,11,8,0.97);
  border-top: 1px solid var(--white-10);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}
.un-footer-logo {
  font-family: 'Syne', sans-serif;
  font-size: 16px;
  font-weight: 800;
  color: var(--white);
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
}
.un-footer-logo span { color: var(--accent); }
.un-footer-links {
  display: flex;
  gap: 32px;
  flex-wrap: wrap;
}
.un-footer-links a {
  font-size: 12px;
  color: var(--white-30);
  text-decoration: none;
  transition: color 0.2s;
  letter-spacing: 0.5px;
}
.un-footer-links a:hover { color: var(--white-60); }
.un-footer-copy {
  font-size: 12px;
  color: var(--white-30);
}
@media (max-width: 768px) {
  .un-footer { padding: 32px 24px; flex-direction: column; align-items: flex-start; }
}
</style>

<footer class="un-footer">
  <a href="/" class="un-footer-logo">Unikněte<span>!</span></a>
  <div class="un-footer-links">
    <a href="/pages/kontakt">Kontakt</a>
    <a href="mailto:uniknete@gmail.com">uniknete@gmail.com</a>
    <a href="tel:+420728984126">+420 728 984 126</a>
    <a href="{{ shop.url }}/policies/privacy-policy">Ochrana dat</a>
    <a href="{{ shop.url }}/policies/refund-policy">Reklamace</a>
  </div>
  <div class="un-footer-copy">© {{ 'now' | date: '%Y' }} Unikněte!</div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
