<style>
.un-footer {
  padding: 40px 48px;
  border-top: 1px solid rgba(17,17,17,0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
  background: #ffffff;
}
.is-homepage .un-footer {
  background: rgba(8,11,8,0.97);
  border-color: rgba(255,255,255,0.06);
}
.un-footer-logo {
  font-family: 'Syne', sans-serif;
  font-size: 16px; font-weight: 800;
  color: #111111; letter-spacing: 2px;
  text-transform: uppercase; text-decoration: none;
}
.is-homepage .un-footer-logo { color: var(--white); }
.un-footer-logo span { color: var(--accent); }
.un-footer-links { display: flex; gap: 28px; flex-wrap: wrap; }
.un-footer-links a {
  font-size: 12px; color: rgba(17,17,17,0.35);
  text-decoration: none; transition: color 0.2s;
}
.is-homepage .un-footer-links a { color: rgba(255,255,255,0.3); }
.un-footer-links a:hover { color: var(--accent); }
.un-footer-copy { font-size: 12px; color: rgba(17,17,17,0.25); }
.is-homepage .un-footer-copy { color: rgba(255,255,255,0.2); }

@media (max-width: 768px) {
  .un-footer { padding: 32px 24px; flex-direction: column; align-items: flex-start; }
}
</style>

<footer class="un-footer">
  <a href="/" class="un-footer-logo">Unikněte<span>!</span></a>
  <div class="un-footer-links">
    <a href="/pages/kontakt">Kontakt</a>
    <a href="mailto:uniknete@gmail.com">uniknete@gmail.com</a>
    <a href="tel:+420728984126">+420 728 984 126</a>
    <a href="{{ shop.url }}/policies/privacy-policy">Ochrana dat</a>
    <a href="{{ shop.url }}/policies/refund-policy">Reklamace</a>
  </div>
  <div class="un-footer-copy">© {{ 'now' | date: '%Y' }} Unikněte!</div>
</footer>

{% schema %}
{ "name": "Footer", "settings": [] }
{% endschema %}
