<style>
.un-how {
  padding: 100px 48px;
  background: rgba(8,11,8,0.9);
  border-top: 1px solid var(--white-10);
}
.un-how-inner {
  max-width: 900px;
  margin: 0 auto;
  text-align: center;
}
.un-how-title {
  font-family: 'Syne', sans-serif;
  font-size: 36px;
  font-weight: 800;
  color: var(--white);
  margin-bottom: 64px;
}
.un-how-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  position: relative;
}
.un-how-steps::before {
  content: '';
  position: absolute;
  top: 28px;
  left: calc(16% + 16px);
  right: calc(16% + 16px);
  height: 1px;
  background: linear-gradient(to right, var(--accent), transparent, var(--accent));
  opacity: 0.3;
}
.un-how-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  padding: 0 24px;
}
.un-how-step-num {
  width: 56px;
  height: 56px;
  border: 1px solid var(--accent-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Syne', sans-serif;
  font-size: 18px;
  font-weight: 800;
  color: var(--accent);
  background: var(--dark);
  position: relative;
  z-index: 1;
  flex-shrink: 0;
}
.un-how-step-title {
  font-family: 'Syne', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--white);
}
.un-how-step-desc {
  font-size: 14px;
  color: var(--white-60);
  line-height: 1.65;
  font-weight: 300;
}
.un-how-cta {
  margin-top: 64px;
}
@media (max-width: 768px) {
  .un-how { padding: 64px 24px; }
  .un-how-steps { grid-template-columns: 1fr; gap: 40px; }
  .un-how-steps::before { display: none; }
}
</style>

<section class="un-how" id="jak">
  <div class="un-how-inner">
    <h2 class="un-how-title">{{ section.settings.title }}</h2>
    <div class="un-how-steps">
      {% for block in section.blocks %}
        <div class="un-how-step" {{ block.shopify_attributes }}>
          <div class="un-how-step-num">{{ forloop.index }}</div>
          <div class="un-how-step-title">{{ block.settings.title }}</div>
          <p class="un-how-step-desc">{{ block.settings.desc }}</p>
        </div>
      {% endfor %}
    </div>
    <div class="un-how-cta">
      <a href="/pages/hry" class="btn-primary">Vybrat hru →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Jak to funguje",
  "settings": [
    { "type": "text", "id": "title", "label": "Nadpis", "default": "Jak to funguje" }
  ],
  "blocks": [
    {
      "type": "step", "name": "Krok",
      "settings": [
        { "type": "text", "id": "title", "label": "Název" },
        { "type": "textarea", "id": "desc", "label": "Popis" }
      ]
    }
  ],
  "presets": [{
    "name": "Jak to funguje",
    "blocks": [
      { "type": "step", "settings": { "title": "Koupíš hru", "desc": "Vyber hru, zaplať online. Hotovo za 2 minuty." } },
      { "type": "step", "settings": { "title": "Dostaneš instrukce", "desc": "Na mail přijde PDF s QR kódem a vším co potřebuješ." } },
      { "type": "step", "settings": { "title": "Hraješ", "desc": "Vyraz ven. Řeš šifry, hledej stopy, dokončete příběh." } }
    ]
  }]
}
{% endschema %}
