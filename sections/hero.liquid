<style>
.un-hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 64px 80px;
  position: relative;
}
.un-hero-content {
  max-width: 720px;
  position: relative;
  z-index: 2;
}
.un-eyebrow {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.un-eyebrow::before {
  content: '';
  display: block;
  width: 32px;
  height: 1px;
  background: var(--gold);
}
.un-hero-title {
  font-family: 'Playfair Display', serif;
  font-size: 88px;
  font-weight: 900;
  line-height: 0.95;
  color: var(--cream);
  margin-bottom: 28px;
  letter-spacing: -1px;
}
.un-hero-title em {
  color: var(--gold);
  font-style: italic;
  display: block;
}
.un-hero-desc {
  font-size: 17px;
  font-weight: 300;
  color: var(--cream-60);
  line-height: 1.75;
  max-width: 480px;
  margin-bottom: 48px;
}
.un-hero-btns {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
}
.un-hero-scroll {
  position: absolute;
  bottom: 40px;
  right: 64px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: var(--cream-40);
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.un-scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); }
  50% { opacity: 1; transform: scaleY(1.1); }
}
.un-hero-stats {
  position: absolute;
  bottom: 80px;
  right: 64px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  text-align: right;
}
.un-hero-stat-num {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--gold);
  display: block;
  line-height: 1;
}
.un-hero-stat-label {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--cream-40);
}
@media (max-width: 900px) {
  .un-hero { padding: 0 24px 64px; }
  .un-hero-title { font-size: 52px; }
  .un-hero-stats { display: none; }
  .un-hero-scroll { right: 24px; }
}
</style>

<section class="un-hero">
  <div class="un-hero-content">
    <div class="un-eyebrow">{{ section.settings.eyebrow }}</div>
    <h1 class="un-hero-title">
      {{ section.settings.title_line1 }}
      <em>{{ section.settings.title_em }}</em>
    </h1>
    <p class="un-hero-desc">{{ section.settings.description }}</p>
    <div class="un-hero-btns">
      <a href="{{ section.settings.btn1_url }}" class="btn-primary">{{ section.settings.btn1_text }}</a>
      <a href="{{ section.settings.btn2_url }}" class="btn-ghost">{{ section.settings.btn2_text }}</a>
    </div>
  </div>

  <div class="un-hero-stats">
    <div>
      <span class="un-hero-stat-num">{{ section.settings.stat1_num }}</span>
      <span class="un-hero-stat-label">{{ section.settings.stat1_label }}</span>
    </div>
    <div>
      <span class="un-hero-stat-num">{{ section.settings.stat2_num }}</span>
      <span class="un-hero-stat-label">{{ section.settings.stat2_label }}</span>
    </div>
  </div>

  <div class="un-hero-scroll">
    <div class="un-scroll-line"></div>
    Scroll
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Venkovní dobrodružství · Děčín" },
    { "type": "text", "id": "title_line1", "label": "Nadpis řádek 1", "default": "Unikni" },
    { "type": "text", "id": "title_em", "label": "Nadpis kurzíva", "default": "z obyčejného" },
    { "type": "textarea", "id": "description", "label": "Popis", "default": "Venkovní únikovky a bojovky, které prověří tvůj tým. Bez zámků, bez místnosti — celé město je tvoje herna." },
    { "type": "text", "id": "btn1_text", "label": "Tlačítko 1", "default": "Prozkoumat hry" },
    { "type": "url", "id": "btn1_url", "label": "Tlačítko 1 odkaz" },
    { "type": "text", "id": "btn2_text", "label": "Tlačítko 2", "default": "Jak to funguje" },
    { "type": "url", "id": "btn2_url", "label": "Tlačítko 2 odkaz" },
    { "type": "text", "id": "stat1_num", "label": "Stat 1 číslo", "default": "3 000+" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 popisek", "default": "Spokojených hráčů" },
    { "type": "text", "id": "stat2_num", "label": "Stat 2 číslo", "default": "★ 4.9" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 popisek", "default": "Průměrné hodnocení" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
