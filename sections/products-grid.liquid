<style>
.un-catalog {
  padding: 100px 48px;
  background: transparent;
  border-top: 1px solid var(--white-10);
}
.un-catalog-header {
  max-width: 1200px;
  margin: 0 auto 56px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24px;
  flex-wrap: wrap;
}
.un-catalog-grid {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  background: transparent;
}
.un-game-card {
  background: rgba(8,11,8,0.45);
  backdrop-filter: blur(4px);
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  transition: background 0.25s;
  position: relative;
  overflow: hidden;
}
.un-game-card:hover { background: rgba(8,11,8,0.65); }
.un-game-card-img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  filter: brightness(0.8) saturate(0.7);
  transition: filter 0.4s, transform 0.5s;
}
.un-game-card:hover .un-game-card-img {
  filter: brightness(0.95) saturate(1);
  transform: scale(1.03);
}
.un-game-card-img-wrap {
  overflow: hidden;
  position: relative;
}
.un-game-card-img-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  background: rgba(8,11,8,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  opacity: 0.3;
}
.un-game-card-body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}
.un-game-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}
.un-game-card-name {
  font-family: 'Syne', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
}
.un-game-card-price {
  font-size: 18px;
  font-weight: 600;
  color: var(--accent);
  white-space: nowrap;
}
.un-game-card-hook {
  font-size: 13px;
  color: var(--white-60);
  line-height: 1.6;
  font-weight: 300;
  font-style: italic;
}
.un-game-card-meta {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.un-game-meta-item {
  font-size: 11px;
  color: var(--white-30);
  display: flex;
  align-items: center;
  gap: 5px;
  letter-spacing: 0.5px;
}
.un-game-meta-item strong { color: var(--white-60); font-weight: 500; }
.un-game-card-footer {
  margin-top: auto;
  padding-top: 16px;
  border-top: 1px solid var(--white-10);
  display: flex;
  justify-content: flex-end;
}
.un-game-card-btn {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 8px;
  transition: gap 0.2s;
}
.un-game-card:hover .un-game-card-btn { gap: 12px; }

@media (max-width: 900px) {
  .un-catalog { padding: 64px 24px; }
  .un-catalog-grid { grid-template-columns: 1fr; }
}
</style>

<section class="un-catalog" id="hry">
  <div class="un-catalog-header">
    <div>
      <span class="section-label">{{ section.settings.label }}</span>
      <h2 class="section-title" style="margin-bottom:0;">{{ section.settings.title }}</h2>
    </div>
    <a href="/pages/hry" class="btn-ghost" style="padding:12px 24px;font-size:12px;">Všechny hry →</a>
  </div>

  <div class="un-catalog-grid">
    {% assign col = collections[section.settings.collection] %}
    {% if col and col.products.size > 0 %}
      {% for product in col.products limit: section.settings.products_count %}
        <a href="{{ product.url }}" class="un-game-card">
          <div class="un-game-card-img-wrap">
            {% if product.featured_image %}
              <img class="un-game-card-img"
                src="{{ product.featured_image | img_url: '800x450', crop: 'center' }}"
                alt="{{ product.title | escape }}"
                loading="lazy" />
            {% else %}
              <div class="un-game-card-img-placeholder">🗺</div>
            {% endif %}
          </div>
          <div class="un-game-card-body">
            <div class="un-game-card-top">
              <div class="un-game-card-name">{{ product.title }}</div>
              <div class="un-game-card-price">{% if product.price > 0 %}od {{ product.price | money }}{% else %}Na vyžádání{% endif %}</div>
            </div>
            {% if product.description != blank %}
              <div class="un-game-card-hook">{{ product.description | strip_html | truncate: 80 }}</div>
            {% endif %}
            <div class="un-game-card-meta">
              <span class="un-game-meta-item">👥 <strong>2–8</strong> hráčů</span>
              <span class="un-game-meta-item">⏱ <strong>90 min</strong></span>
              {% if product.available %}
                <span class="badge" style="font-size:9px;">Dostupné</span>
              {% endif %}
            </div>
            <div class="un-game-card-footer">
              <span class="un-game-card-btn">Koupit voucher →</span>
            </div>
          </div>
        </a>
      {% endfor %}
    {% else %}
      <p style="color:var(--white-30);grid-column:1/-1;padding:48px;text-align:center;">Přidej kolekci v nastavení sekce.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Katalog her",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Katalog her" },
    { "type": "text", "id": "title", "label": "Nadpis", "default": "Vyber svůj příběh" },
    { "type": "collection", "id": "collection", "label": "Kolekce" },
    { "type": "range", "id": "products_count", "min": 2, "max": 9, "step": 1, "label": "Počet her", "default": 6 }
  ],
  "presets": [{ "name": "Katalog her" }]
}
{% endschema %}
