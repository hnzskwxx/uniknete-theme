<style>
.un-how {
  padding: 100px 64px;
  background: rgba(10,15,8,0.85);
  backdrop-filter: blur(8px);
  border-top: 1px solid rgba(240,235,224,0.06);
}
.un-how-inner {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 80px;
  align-items: start;
}
.un-how-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  counter-reset: steps;
}
.un-how-step {
  padding: 32px 0;
  border-bottom: 1px solid var(--cream-08);
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 20px;
  align-items: start;
}
.un-how-step:first-child { padding-top: 0; }
.un-how-step:last-child { border-bottom: none; }
.un-step-num {
  font-family: 'Playfair Display', serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 1px;
  padding-top: 3px;
}
.un-step-title {
  font-size: 17px;
  font-weight: 500;
  color: var(--cream);
  margin-bottom: 8px;
}
.un-step-desc {
  font-size: 13px;
  color: var(--cream-40);
  line-height: 1.7;
  font-weight: 300;
}
@media (max-width: 900px) {
  .un-how { padding: 64px 24px; }
  .un-how-inner { grid-template-columns: 1fr; gap: 48px; }
}
</style>

<section class="un-how" id="jak">
  <div class="un-how-inner">
    <div>
      <span class="section-label">{{ section.settings.label }}</span>
      <h2 class="section-title">{{ section.settings.title }}</h2>
      <p class="section-sub" style="margin-top:16px;">{{ section.settings.subtitle }}</p>
      <a href="/collections/all" class="btn-primary" style="margin-top:40px;">Začít teď</a>
    </div>
    <div class="un-how-steps">
      {% for block in section.blocks %}
        <div class="un-how-step" {{ block.shopify_attributes }}>
          <div class="un-step-num">0{{ forloop.index }}</div>
          <div>
            <div class="un-step-title">{{ block.settings.title }}</div>
            <p class="un-step-desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Jak to funguje",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Jak to funguje" },
    { "type": "text", "id": "title", "label": "Nadpis", "default": "Tři kroky k dobrodružství" },
    { "type": "text", "id": "subtitle", "label": "Podnadpis", "default": "Od objednávky ke hře za pár minut. Žádná registrace, žádné čekání." }
  ],
  "blocks": [
    {
      "type": "step", "name": "Krok",
      "settings": [
        { "type": "text", "id": "title", "label": "Název" },
        { "type": "textarea", "id": "description", "label": "Popis" }
      ]
    }
  ],
  "presets": [{
    "name": "Jak to funguje",
    "blocks": [
      { "type": "step", "settings": { "title": "Vyber a zaplať online", "description": "Vyber hru, zaplať kartou nebo přes PayPal. Celý proces trvá méně než 2 minuty." } },
      { "type": "step", "settings": { "title": "Dostaneš voucher e-mailem", "description": "Okamžitě po platbě ti přijde PDF s QR kódem. Vytiskni nebo ukaž v telefonu." } },
      { "type": "step", "settings": { "title": "Unikni a vyhraj", "description": "Vyraz ven, řeš šifry, spolupracuj s týmem. Platnost voucheru 12 měsíců." } }
    ]
  }]
}
{% endschema %}