<style>
.un-reviews {
  padding: 100px 64px;
  background: rgba(10,15,8,0.6);
  backdrop-filter: blur(4px);
  border-top: 1px solid rgba(240,235,224,0.06);
}
.un-reviews-header { margin-bottom: 56px; }
.un-reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.un-review-card {
  background: rgba(10,15,8,0.7);
  backdrop-filter: blur(8px);
  border: 1px solid var(--cream-08);
  border-radius: 2px;
  padding: 32px;
  transition: border-color 0.3s;
}
.un-review-card:hover { border-color: var(--gold-30); }
.un-stars { color: var(--gold); font-size: 13px; letter-spacing: 3px; margin-bottom: 18px; }
.un-review-text {
  font-size: 15px;
  color: rgba(240,235,224,0.7);
  line-height: 1.75;
  font-weight: 300;
  margin-bottom: 24px;
  font-style: italic;
}
.un-review-author {
  font-size: 11px;
  font-weight: 500;
  color: var(--cream-40);
  letter-spacing: 2px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
}
.un-review-author::before {
  content: '';
  display: block;
  width: 20px;
  height: 1px;
  background: var(--gold);
}
@media (max-width: 900px) {
  .un-reviews { padding: 64px 24px; }
  .un-reviews-grid { grid-template-columns: 1fr; }
}
</style>

<section class="un-reviews" id="recenze">
  <div class="un-reviews-header">
    <span class="section-label">{{ section.settings.label }}</span>
    <h2 class="section-title">{{ section.settings.title }}</h2>
  </div>
  <div class="un-reviews-grid">
    {% for block in section.blocks %}
      <div class="un-review-card" {{ block.shopify_attributes }}>
        <div class="un-stars">★★★★★</div>
        <p class="un-review-text">"{{ block.settings.text }}"</p>
        <div class="un-review-author">{{ block.settings.author }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Recenze",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Recenze" },
    { "type": "text", "id": "title", "label": "Nadpis", "default": "Co říkají hráči" }
  ],
  "blocks": [
    {
      "type": "review", "name": "Recenze",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Text" },
        { "type": "text", "id": "author", "label": "Autor" }
      ]
    }
  ],
  "presets": [{
    "name": "Recenze",
    "blocks": [
      { "type": "review", "settings": { "text": "Naprosto skvělý zážitek! Strávili jsme s rodinou skoro 2 hodiny hledáním stop po celém centru.", "author": "Markéta H. · Děčín" } },
      { "type": "review", "settings": { "text": "Perfektní teambuilding! Kolektiv se skvěle sehrál, hry jsou vymyšlené s citem. Příští rok zase.", "author": "Tomáš B. · Praha" } },
      { "type": "review", "settings": { "text": "Papírovou verzi jsme hráli na chalupě — geniální nápad. Šifry byly přiměřeně těžké, bavily se i děti.", "author": "Jana K. · Liberec" } }
    ]
  }]
}
{% endschema %}
