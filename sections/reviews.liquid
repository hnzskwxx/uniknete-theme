<style>
.un-reviews {
  padding: 100px 48px;
  background: rgba(8,11,8,0.75);
  border-top: 1px solid var(--white-10);
}
.un-reviews-inner { max-width: 1100px; margin: 0 auto; }
.un-reviews-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 56px;
  flex-wrap: wrap;
  gap: 16px;
}
.un-reviews-count {
  font-family: 'Syne', sans-serif;
  font-size: 48px;
  font-weight: 800;
  color: var(--accent);
  line-height: 1;
}
.un-reviews-count-label {
  font-size: 13px;
  color: var(--white-60);
  font-weight: 300;
}
.un-reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: var(--white-10);
}
.un-review-card {
  background: var(--dark);
  padding: 32px;
}
.un-stars {
  color: var(--accent);
  font-size: 13px;
  letter-spacing: 2px;
  margin-bottom: 16px;
}
.un-review-text {
  font-size: 15px;
  color: var(--white-60);
  line-height: 1.75;
  font-weight: 300;
  margin-bottom: 20px;
}
.un-review-author {
  font-size: 12px;
  color: var(--white-30);
  font-weight: 500;
  letter-spacing: 1px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
}
.un-review-author::before {
  content: '';
  display: block;
  width: 16px;
  height: 1px;
  background: var(--accent);
}
@media (max-width: 900px) {
  .un-reviews { padding: 64px 24px; }
  .un-reviews-grid { grid-template-columns: 1fr; }
}
</style>

<section class="un-reviews" id="recenze">
  <div class="un-reviews-inner">
    <div class="un-reviews-header">
      <div>
        <span class="section-label">{{ section.settings.label }}</span>
        <h2 class="section-title" style="margin-bottom:0;">{{ section.settings.title }}</h2>
      </div>
      <div style="text-align:right;">
        <div class="un-reviews-count">{{ section.settings.count }}</div>
        <div class="un-reviews-count-label">spokojených hráčů</div>
      </div>
    </div>
    <div class="un-reviews-grid">
      {% for block in section.blocks %}
        <div class="un-review-card" {{ block.shopify_attributes }}>
          <div class="un-stars">★★★★★</div>
          <p class="un-review-text">{{ block.settings.text }}</p>
          <div class="un-review-author">{{ block.settings.author }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Recenze",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Sociální důkaz" },
    { "type": "text", "id": "title", "label": "Nadpis", "default": "Co říkají hráči" },
    { "type": "text", "id": "count", "label": "Počet hráčů", "default": "3 000+" }
  ],
  "blocks": [
    {
      "type": "review", "name": "Recenze",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Text recenze" },
        { "type": "text", "id": "author", "label": "Autor" }
      ]
    }
  ],
  "presets": [{
    "name": "Recenze",
    "blocks": [
      { "type": "review", "settings": { "text": "Naprosto skvělý zážitek! Strávili jsme s rodinou skoro 2 hodiny hledáním stop po celém centru.", "author": "Markéta H. · Děčín" } },
      { "type": "review", "settings": { "text": "Perfektní teambuilding. Kolektiv se skvěle sehrál, hry jsou vymyšlené s citem.", "author": "Tomáš B. · Praha" } },
      { "type": "review", "settings": { "text": "Papírovou verzi jsme hráli na chalupě — geniální nápad. Bavily se i děti.", "author": "Jana K. · Liberec" } }
    ]
  }]
}
{% endschema %}
