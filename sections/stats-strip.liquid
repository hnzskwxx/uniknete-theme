<style>
.un-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: var(--dark-3);
  border-top: 1px solid var(--cream-08);
  border-bottom: 1px solid var(--cream-08);
}
.un-stat {
  text-align: center;
  padding: 44px 24px;
  border-right: 1px solid var(--cream-08);
}
.un-stat:last-child { border-right: none; }
.un-stat-num {
  font-family: 'Playfair Display', serif;
  font-size: 42px;
  font-weight: 700;
  color: var(--gold);
  display: block;
  line-height: 1;
  margin-bottom: 8px;
}
.un-stat-label {
  font-size: 12px;
  color: var(--cream-40);
  letter-spacing: 1px;
  text-transform: uppercase;
}
@media (max-width: 768px) {
  .un-stats { grid-template-columns: repeat(2, 1fr); }
  .un-stat:nth-child(2) { border-right: none; }
  .un-stat { border-bottom: 1px solid var(--cream-08); }
}
</style>

<div class="un-stats">
  {% for block in section.blocks %}
    <div class="un-stat" {{ block.shopify_attributes }}>
      <span class="un-stat-num">{{ block.settings.number }}</span>
      <span class="un-stat-label">{{ block.settings.label }}</span>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Stats strip",
  "blocks": [
    {
      "type": "stat",
      "name": "Statistika",
      "settings": [
        { "type": "text", "id": "number", "label": "Číslo", "default": "12+" },
        { "type": "text", "id": "label", "label": "Popisek", "default": "Unikátních her" }
      ]
    }
  ],
  "presets": [{
    "name": "Stats strip",
    "blocks": [
      { "type": "stat", "settings": { "number": "12+", "label": "Unikátních her" } },
      { "type": "stat", "settings": { "number": "3 000+", "label": "Spokojených hráčů" } },
      { "type": "stat", "settings": { "number": "4.9", "label": "Průměrné hodnocení" } },
      { "type": "stat", "settings": { "number": "Online", "label": "i papírové verze" } }
    ]
  }]
}
{% endschema %}
