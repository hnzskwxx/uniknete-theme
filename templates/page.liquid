<style>
.un-page {
  padding-top: 80px;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 80px;
}
.un-page-wrap {
  max-width: 760px;
  width: 100%;
  padding: 0 32px;
  background: rgba(8,11,8,0.65);
  backdrop-filter: blur(12px);
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 48px;
}
.un-page-label {
  font-size: 10px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent);
  font-weight: 600; margin-bottom: 16px; display: block;
}
.un-page-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 800; color: var(--white);
  line-height: 1.1; letter-spacing: -1px; margin-bottom: 32px;
}
.un-page-content {
  font-size: 15px; color: rgba(240,237,232,0.6);
  line-height: 1.8; font-weight: 300;
}
.un-page-content h2 {
  font-family: 'Syne', sans-serif;
  font-size: 20px; font-weight: 700;
  color: var(--white); margin: 28px 0 10px;
}
.un-page-content p { margin-bottom: 14px; }
.un-page-content a { color: var(--accent); }
.un-page-content strong { color: var(--white); font-weight: 600; }

@media (max-width: 768px) {
  .un-page-wrap { padding: 32px 24px; }
}
</style>

<div class="un-page">
  <div class="un-page-wrap">
    <span class="un-page-label">{{ page.title }}</span>
    <h1 class="un-page-title">{{ page.title }}</h1>
    <div class="un-page-content">{{ page.content }}</div>
  </div>
</div>
