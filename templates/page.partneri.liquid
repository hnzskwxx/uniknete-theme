<style>
.un-partneri { padding-top: 80px; min-height: 100vh; }

.un-partneri-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 64px 32px 80px;
  display: flex;
  flex-direction: column;
  gap: 56px;
}

/* HERO TEXT */
.un-partneri-hero { max-width: 600px; }
.un-partneri-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 800; color: var(--white);
  line-height: 1.0; letter-spacing: -1px; margin-bottom: 14px;
}
.un-partneri-title span { color: var(--accent); }
.un-partneri-sub {
  font-size: 16px; color: rgba(240,237,232,0.55);
  font-weight: 300; line-height: 1.7;
}

/* GRID 1fr 1.2fr 1fr — prostřední větší */
.un-partneri-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr 1fr;
  gap: 24px;
  align-items: stretch;
}

/* KARTA */
.un-partner-card {
  background: rgba(8,11,8,0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 8px 32px rgba(0,0,0,0.35);
  padding: 32px 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  text-decoration: none;
  color: inherit;
  transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s;
}
.un-partner-card:hover {
  transform: scale(1.025);
  background: rgba(8,11,8,0.78);
  box-shadow: 0 20px 56px rgba(0,0,0,0.5);
}

/* Prostřední karta — featured */
.un-partner-card.featured {
  border-color: rgba(255,107,53,0.2);
  padding: 40px 32px;
}
.un-partner-card.featured .un-partner-name {
  font-size: 24px;
}

/* LOGO */
.un-partner-logo-wrap {
  height: 72px;
  display: flex;
  align-items: center;
}
.un-partner-logo {
  max-height: 60px;
  max-width: 160px;
  width: auto;
  object-fit: contain;
  object-position: left center;
}
.un-partner-logo-placeholder {
  font-family: 'Syne', sans-serif;
  font-size: 28px; font-weight: 800;
  color: var(--accent);
  background: rgba(255,107,53,0.1);
  border: 1px solid rgba(255,107,53,0.2);
  border-radius: 10px;
  width: 60px; height: 60px;
  display: flex; align-items: center; justify-content: center;
}

/* DIVIDER */
.un-partner-divider {
  height: 1px;
  background: rgba(255,255,255,0.07);
}

/* TEXT */
.un-partner-type {
  font-size: 10px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent);
  font-weight: 600;
}
.un-partner-name {
  font-family: 'Syne', sans-serif;
  font-size: 20px; font-weight: 800;
  color: var(--white); line-height: 1.15;
}
.un-partner-desc {
  font-size: 14px; color: rgba(240,237,232,0.55);
  font-weight: 300; line-height: 1.7; flex: 1;
}

/* ODKAZ */
.un-partner-link {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 12px; font-weight: 600;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--accent);
  padding-top: 4px;
  transition: gap 0.2s;
}
.un-partner-card:hover .un-partner-link { gap: 12px; }

/* TABLET */
@media (max-width: 900px) {
  .un-partneri-grid { grid-template-columns: 1fr 1fr; }
  .un-partner-card:last-child { grid-column: 1 / 3; max-width: 480px; margin: 0 auto; width: 100%; }
}

/* MOBILE */
@media (max-width: 600px) {
  .un-partneri-wrap { padding: 48px 20px 64px; }
  .un-partneri-grid { grid-template-columns: 1fr; }
  .un-partner-card:last-child { grid-column: auto; max-width: none; }
}
</style>

