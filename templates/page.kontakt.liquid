<style>
.un-kontakt-page {
  padding-top: 80px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-bottom: 80px;
}

.un-kontakt-inner {
  width: 100%;
  max-width: 1000px;
  padding: 0 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}

/* LEVÁ STRANA */
.un-kontakt-left {
  padding-top: 16px;
}
.un-kontakt-title {
  font-family: 'Playfair Display', serif;
  font-size: 56px;
  font-weight: 900;
  color: var(--cream);
  line-height: 1.0;
  margin-bottom: 20px;
}
.un-kontakt-title em { color: var(--gold); font-style: italic; }
.un-kontakt-sub {
  font-size: 16px;
  color: var(--cream-60);
  font-weight: 300;
  line-height: 1.75;
  margin-bottom: 48px;
}
.un-kontakt-items {
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.un-kontakt-item {
  display: flex;
  align-items: center;
  gap: 16px;
}
.un-kontakt-icon {
  width: 44px; height: 44px;
  background: rgba(212,168,71,0.1);
  border: 1px solid var(--gold-30);
  border-radius: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 18px;
}
.un-kontakt-item-label {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 4px;
  display: block;
}
.un-kontakt-item-value {
  font-size: 16px;
  color: var(--cream);
  font-weight: 400;
  text-decoration: none;
  transition: color 0.2s;
}
.un-kontakt-item-value:hover { color: var(--gold); }

/* PRAVÁ STRANA - formulář */
.un-kontakt-form-wrap {
  background: rgba(10,15,8,0.82);
  backdrop-filter: blur(16px);
  border: 1px solid var(--cream-08);
  border-radius: 4px;
  padding: 48px 40px;
}
.un-kontakt-form-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--cream);
  margin-bottom: 32px;
  line-height: 1.2;
}
.un-kontakt-form-title em { color: var(--gold); font-style: italic; }
.un-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.un-form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.un-form-group {
  display: flex;
  flex-direction: column;
  gap: 7px;
}
.un-form-group label {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--cream-40);
}
.un-form-group input,
.un-form-group textarea {
  background: rgba(240,235,224,0.04);
  border: 1px solid rgba(240,235,224,0.12);
  border-radius: 2px;
  padding: 12px 16px;
  color: var(--cream);
  font-size: 14px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  transition: border-color 0.2s, background 0.2s;
  outline: none;
  width: 100%;
}
.un-form-group input::placeholder,
.un-form-group textarea::placeholder { color: rgba(240,235,224,0.25); }
.un-form-group input:focus,
.un-form-group textarea:focus {
  border-color: var(--gold);
  background: rgba(212,168,71,0.04);
}
.un-form-group textarea { resize: vertical; min-height: 110px; }
.un-form-success {
  color: var(--gold);
  font-size: 14px;
  padding: 14px 16px;
  border: 1px solid var(--gold-30);
  border-radius: 2px;
  background: rgba(212,168,71,0.06);
}

@media (max-width: 900px) {
  .un-kontakt-inner { grid-template-columns: 1fr; gap: 40px; padding: 0 24px; }
  .un-kontakt-title { font-size: 40px; }
  .un-form-row { grid-template-columns: 1fr; }
  .un-kontakt-form-wrap { padding: 32px 24px; }
}
</style>

<div class="un-kontakt-page">
  <div class="un-kontakt-inner">

    <div class="un-kontakt-left">
      <span class="section-label">Kontakt</span>
      <h1 class="un-kontakt-title">Spojte se<br><em>s námi</em></h1>
      <p class="un-kontakt-sub">Máte otázku nebo zájem o průvodce na míru? Ozveme se co nejdříve.</p>
      <div class="un-kontakt-items">
        <div class="un-kontakt-item">
          <div class="un-kontakt-icon">📱</div>
          <div>
            <span class="un-kontakt-item-label">Telefon</span>
            <a href="tel:+420728984126" class="un-kontakt-item-value">+420 728 984 126</a>
          </div>
        </div>
        <div class="un-kontakt-item">
          <div class="un-kontakt-icon">📧</div>
          <div>
            <span class="un-kontakt-item-label">E-mail</span>
            <a href="mailto:uniknete@gmail.com" class="un-kontakt-item-value">uniknete@gmail.com</a>
          </div>
        </div>
      </div>
    </div>

    <div class="un-kontakt-form-wrap">
      <h2 class="un-kontakt-form-title">Kontaktujte <em>nás!</em></h2>
      {% form 'contact', class: 'un-form' %}
        {{ form.errors | default_errors }}
        {% if form.posted_successfully? %}
          <p class="un-form-success">✓ Zpráva odeslána! Ozveme se co nejdříve.</p>
        {% endif %}
        <div class="un-form-row">
          <div class="un-form-group">
            <label>Jméno</label>
            <input type="text" name="contact[name]" placeholder="Vaše jméno" required />
          </div>
          <div class="un-form-group">
            <label>Telefon</label>
            <input type="tel" name="contact[phone]" placeholder="+420 000 000 000" />
          </div>
        </div>
        <div class="un-form-group">
          <label>E-mail</label>
          <input type="email" name="contact[email]" placeholder="vas@email.cz" required />
        </div>
        <div class="un-form-group">
          <label>Zpráva</label>
          <textarea name="contact[body]" placeholder="Napište nám co potřebujete..." required></textarea>
        </div>
        <button type="submit" class="btn-primary" style="width:100%;text-align:center;padding:15px;">Odeslat zprávu →</button>
      {% endform %}
    </div>

  </div>
</div>
