<style>
.un-kontakt-page {
  padding-top: 80px;
  min-height: 100vh;
}
.un-kontakt-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
}

/* LEVÁ STRANA */
.un-kontakt-left {
  padding: 80px 64px;
  background: transparent;
  border-right: 1px solid var(--cream-08);
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.un-kontakt-title {
  font-family: 'Playfair Display', serif;
  font-size: 56px;
  font-weight: 900;
  color: var(--cream);
  line-height: 1.0;
  margin-bottom: 16px;
}
.un-kontakt-title em { color: var(--gold); font-style: italic; }
.un-kontakt-sub {
  font-size: 16px;
  color: var(--cream-40);
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 56px;
  max-width: 400px;
}
.un-kontakt-items {
  display: flex;
  flex-direction: column;
  gap: 28px;
}
.un-kontakt-item {
  display: flex;
  align-items: center;
  gap: 20px;
}
.un-kontakt-icon {
  width: 48px; height: 48px;
  background: rgba(212,168,71,0.1);
  border: 1px solid var(--gold-30);
  border-radius: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 20px;
}
.un-kontakt-item-label {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--cream-40);
  margin-bottom: 4px;
  display: block;
}
.un-kontakt-item-value {
  font-size: 17px;
  color: var(--cream);
  font-weight: 400;
  text-decoration: none;
  transition: color 0.2s;
}
.un-kontakt-item-value:hover { color: var(--gold); }

/* PRAVÁ STRANA - formulář */
.un-kontakt-right {
  padding: 80px 64px;
  background: rgba(10,15,8,0.85);
  backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
}
.un-kontakt-form-title {
  font-family: 'Playfair Display', serif;
  font-size: 32px;
  font-weight: 700;
  color: var(--cream);
  margin-bottom: 36px;
  line-height: 1.2;
}
.un-kontakt-form-title em { color: var(--gold); font-style: italic; }
.un-form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.un-form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.un-form-group label {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--cream-40);
  font-weight: 500;
}
.un-form-group input,
.un-form-group textarea,
.un-form-group select {
  background: rgba(240,235,224,0.05);
  border: 1px solid var(--cream-20);
  border-radius: 2px;
  padding: 14px 18px;
  color: var(--cream);
  font-size: 15px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  transition: border-color 0.2s;
  outline: none;
  width: 100%;
}
.un-form-group input::placeholder,
.un-form-group textarea::placeholder { color: var(--cream-40); }
.un-form-group input:focus,
.un-form-group textarea:focus { border-color: var(--gold); background: rgba(212,168,71,0.04); }
.un-form-group textarea { resize: vertical; min-height: 130px; }
.un-form-success {
  color: var(--gold);
  font-size: 15px;
  padding: 16px;
  border: 1px solid var(--gold-30);
  border-radius: 2px;
  background: rgba(212,168,71,0.08);
}

@media (max-width: 900px) {
  .un-kontakt-wrap { grid-template-columns: 1fr; }
  .un-kontakt-left { padding: 64px 24px; }
  .un-kontakt-right { padding: 48px 24px; }
  .un-kontakt-title { font-size: 40px; }
}
</style>

<div class="un-kontakt-page">
  <div class="un-kontakt-wrap">

    <div class="un-kontakt-left">
      <span class="section-label">Kontakt</span>
      <h1 class="un-kontakt-title">Spojte se<br><em>s námi</em></h1>
      <p class="un-kontakt-sub">Máte otázku, zájem o průvodce na míru nebo jen chcete vědět víc? Ozveme se co nejdříve.</p>

      <div class="un-kontakt-items">
        <div class="un-kontakt-item">
          <div class="un-kontakt-icon">📱</div>
          <div>
            <span class="un-kontakt-item-label">Telefon</span>
            <a href="tel:+420728984126" class="un-kontakt-item-value">+420 728 984 126</a>
          </div>
        </div>
        <div class="un-kontakt-item">
          <div class="un-kontakt-icon">📧</div>
          <div>
            <span class="un-kontakt-item-label">E-mail</span>
            <a href="mailto:uniknete@gmail.com" class="un-kontakt-item-value">uniknete@gmail.com</a>
          </div>
        </div>
      </div>
    </div>

    <div class="un-kontakt-right">
      <h2 class="un-kontakt-form-title">Kontaktujte <em>nás!</em></h2>

      {% form 'contact', class: 'un-form' %}
        {{ form.errors | default_errors }}
        {% if form.posted_successfully? %}
          <p class="un-form-success">✓ Zpráva odeslána! Ozveme se co nejdříve.</p>
        {% endif %}

        <div class="un-form-group">
          <label for="contact-name">Jméno</label>
          <input type="text" id="contact-name" name="contact[name]" placeholder="Vaše jméno" required />
        </div>
        <div class="un-form-group">
          <label for="contact-email">E-mail</label>
          <input type="email" id="contact-email" name="contact[email]" placeholder="vas@email.cz" required />
        </div>
        <div class="un-form-group">
          <label for="contact-phone">Telefon</label>
          <input type="tel" id="contact-phone" name="contact[phone]" placeholder="+420 000 000 000" />
        </div>
        <div class="un-form-group">
          <label for="contact-message">Zpráva</label>
          <textarea id="contact-message" name="contact[body]" placeholder="Napište nám co potřebujete..." required></textarea>
        </div>
        <button type="submit" class="btn-primary" style="width:100%;text-align:center;padding:16px;">Odeslat zprávu →</button>
      {% endform %}
    </div>

  </div>
</div>
