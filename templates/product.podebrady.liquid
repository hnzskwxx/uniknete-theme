<style>
.un-product { padding-top: 80px; }
.un-product-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 48px 32px 80px;
  display: flex; flex-direction: column; gap: 40px;
}

/* HERO */
.un-product-hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  align-items: start;
}
.un-product-main-img {
  aspect-ratio: 1/1;
  background: rgba(8,11,8,0.55);
  backdrop-filter: blur(10px);
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  padding: 24px;
}
.un-product-main-img img {
  width: 100%; height: 100%;
  object-fit: contain; border-radius: 8px;
}
.un-product-info {
  background: rgba(8,11,8,0.6);
  backdrop-filter: blur(14px);
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 16px 48px rgba(0,0,0,0.35);
  padding: 36px;
  display: flex; flex-direction: column; gap: 16px;
}
.un-product-type {
  font-size: 10px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent); font-weight: 600;
}
.un-product-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(28px, 3vw, 44px);
  font-weight: 800; color: var(--white);
  line-height: 1.05; letter-spacing: -1px;
}
.un-product-tagline {
  font-size: 15px; color: rgba(240,237,232,0.55);
  font-weight: 300; line-height: 1.7;
  padding-bottom: 20px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.un-product-meta-mini {
  display: flex; gap: 20px; flex-wrap: wrap;
}
.un-product-meta-mini-item {
  font-size: 13px; color: rgba(240,237,232,0.5); font-weight: 300;
}
.un-product-meta-mini-item strong { color: var(--white); font-weight: 600; }

/* NÁKUPNÍ VARIANTY — 2 karty 50/50 */
.un-purchase-heading {
  font-family: 'Syne', sans-serif;
  font-size: 13px; font-weight: 700;
  color: var(--accent); letter-spacing: 2px;
  text-transform: uppercase; margin-bottom: 20px;
}
.un-purchase-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.un-purchase-card {
  background: rgba(8,11,8,0.6);
  backdrop-filter: blur(10px);
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  padding: 28px;
  display: flex; flex-direction: column; gap: 14px;
  text-decoration: none; color: inherit;
  transition: transform 0.2s ease, box-shadow 0.2s, background 0.2s;
}
.un-purchase-card:hover {
  transform: scale(1.02);
  background: rgba(8,11,8,0.8);
  box-shadow: 0 20px 48px rgba(0,0,0,0.5);
}
.un-purchase-card.main { border-color: rgba(255,107,53,0.3); }

.un-purchase-badge {
  display: inline-block;
  font-size: 9px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 4px 10px; border-radius: 6px;
  width: fit-content;
}
.un-purchase-badge.accent { background: var(--accent); color: #fff; }
.un-purchase-badge.muted {
  background: rgba(255,255,255,0.07);
  color: rgba(240,237,232,0.5);
  border: 1px solid rgba(255,255,255,0.08);
}
.un-purchase-name {
  font-family: 'Syne', sans-serif;
  font-size: 20px; font-weight: 800;
  color: var(--white); line-height: 1.15;
}
.un-purchase-price-row {
  display: flex; align-items: baseline; gap: 4px;
  padding: 12px 0;
  border-top: 1px solid rgba(255,255,255,0.07);
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.un-purchase-price-num {
  font-family: 'Syne', sans-serif;
  font-size: 34px; font-weight: 800; color: var(--white);
}
.un-purchase-price-kc {
  font-size: 15px; font-weight: 700;
  color: rgba(240,237,232,0.5); margin-left: 2px;
}
.un-purchase-desc {
  font-size: 13px; color: rgba(240,237,232,0.5);
  font-weight: 300; line-height: 1.6; flex: 1;
}
.un-purchase-cta {
  display: block; text-align: center;
  padding: 14px 16px; border-radius: 10px;
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  transition: background 0.2s; text-decoration: none;
}
.un-purchase-cta.primary { background: var(--accent); color: #fff; }
.un-purchase-cta.primary:hover { background: #ff824d; }
.un-purchase-cta.ghost {
  background: rgba(255,255,255,0.07); color: var(--white);
  border: 1px solid rgba(255,255,255,0.1);
}
.un-purchase-cta.ghost:hover { background: rgba(255,255,255,0.13); }

/* META KARTY */
.un-product-meta-grid {
  display: grid; grid-template-columns: repeat(4,1fr); gap: 12px;
}
.un-product-meta-card {
  background: rgba(8,11,8,0.55);
  backdrop-filter: blur(10px);
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.07);
  padding: 18px 16px; text-align: center;
  display: flex; flex-direction: column; gap: 6px;
}
.un-meta-icon { font-size: 22px; }
.un-meta-label {
  font-size: 9px; letter-spacing: 2px;
  text-transform: uppercase; color: rgba(240,237,232,0.35); font-weight: 500;
}
.un-meta-value {
  font-family: 'Syne', sans-serif;
  font-size: 15px; font-weight: 700; color: var(--white);
}


/* VOUCHER */
.un-voucher-box {
  max-width: 800px; margin: 0 auto; width: 100%;
  background: rgba(8,11,8,0.55);
  backdrop-filter: blur(10px);
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 40px;
}
.un-voucher-label {
  font-size: 11px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--accent); margin-bottom: 14px;
}
.un-voucher-title {
  font-family: 'Syne', sans-serif;
  font-size: 22px; font-weight: 800;
  color: var(--white); margin-bottom: 12px; line-height: 1.2;
}
.un-voucher-desc {
  font-size: 15px; color: rgba(240,237,232,0.55);
  font-weight: 300; line-height: 1.7; margin-bottom: 28px;
}

@media (max-width: 900px) {
  .un-product-wrap { padding: 32px 20px 80px; gap: 32px; }
  .un-product-hero { grid-template-columns: 1fr; }
  .un-purchase-grid-2 { grid-template-columns: 1fr; }
  .un-product-meta-grid { grid-template-columns: repeat(2,1fr); }
  .un-product-desc-box { grid-template-columns: 1fr; gap: 32px; padding: 28px; }
}
</style>

<div class="un-product">
  <div class="un-product-wrap">

    <!-- HERO -->
    <div class="un-product-hero">
      <div class="un-product-main-img">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | img_url: '700x700' }}" alt="{{ product.title | escape }}" loading="eager" />
        {% else %}
          <div style="font-size:80px;opacity:0.1;">🗺</div>
        {% endif %}
      </div>
      <div class="un-product-info">
        <div class="un-product-type">{{ product.type | default: 'Venkovní hra' }}</div>
        <h1 class="un-product-title">{{ product.title }}</h1>
        <p class="un-product-tagline">{{ product.description | strip_html | truncate: 140 }}</p>
        <div class="un-product-meta-mini">
          <div class="un-product-meta-mini-item">👥 <strong>2–8</strong> hráčů</div>
          <div class="un-product-meta-mini-item">⏱ <strong>60–120 min</strong></div>
          <div class="un-product-meta-mini-item">🎯 <strong>Střední</strong> obtížnost</div>
          <div class="un-product-meta-mini-item">📅 platnost <strong>12 měsíců</strong></div>
        </div>
        <div style="border-top:1px solid rgba(255,255,255,0.07);padding-top:16px;">
          <div style="font-size:11px;font-weight:700;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;">Co dostaneš</div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <div style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,237,232,0.65);font-weight:300;"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;display:inline-block;"></span>PDF voucher s QR kódem (e-mailem)</div>
            <div style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,237,232,0.65);font-weight:300;"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;display:inline-block;"></span>Herní instrukce krok za krokem</div>
            <div style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,237,232,0.65);font-weight:300;"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;display:inline-block;"></span>Podpora na telefonu během hry</div>
          </div>
        </div>
        <div style="border-top:1px solid rgba(255,255,255,0.07);padding-top:16px;">
          <div style="font-size:11px;font-weight:700;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;">Jak to funguje</div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <div style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,237,232,0.65);font-weight:300;"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;display:inline-block;"></span>Vybereš variantu a zaplatíš online</div>
            <div style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,237,232,0.65);font-weight:300;"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;display:inline-block;"></span>Dostaneš instrukce e-mailem</div>
            <div style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,237,232,0.65);font-weight:300;"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;display:inline-block;"></span>Vyrazíš ven a hraješ</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 2 NÁKUPNÍ VARIANTY -->
    <div>
      <div class="un-purchase-heading">Možnosti nákupu</div>
      <div class="un-purchase-grid-2">

        <a href="https://buy.stripe.com/4gM28rack6pW7rl0OobAs06" target="_blank" class="un-purchase-card main">
          <span class="un-purchase-badge accent">Nejoblíbenější</span>
          <div class="un-purchase-name">Online hra</div>
          <div class="un-purchase-price-row">
            <span class="un-purchase-price-num">397</span>
            <span class="un-purchase-price-kc">Kč</span>
          </div>
          <p class="un-purchase-desc">Okamžitý přístup po zaplacení. Voucher s QR kódem e-mailem.</p>
          <span class="un-purchase-cta primary">Koupit ihned →</span>
        </a>

        <a href="https://www.skvelecesko.cz/venkovni-online-hra-husitska-tajemstvi-podebrad-a5248" target="_blank" class="un-purchase-card">
          <span class="un-purchase-badge muted">Firemní benefity</span>
          <div class="un-purchase-name">Firemní benefity</div>
          <div class="un-purchase-price-row">
            <span class="un-purchase-price-num">379</span>
            <span class="un-purchase-price-kc">Kč</span>
          </div>
          <p class="un-purchase-desc">Uplatnění přes Skvélé Česko. Ideální pro firemní benefity.</p>
          <span class="un-purchase-cta ghost">Koupit u partnera →</span>
        </a>

      </div>
    </div>
    <!-- UPLATNĚNÍ VOUCHERU -->
    <div class="un-voucher-box">
      <div class="un-voucher-label">Uplatnění voucheru</div>
      <div class="un-voucher-title">Máte voucher ze slevového portálu?</div>
      <p class="un-voucher-desc">Máte voucher z některého ze slevových portálů (Skvélé Česko apod.)? Pokračujte k uplatnění voucheru.</p>
      <div style="border-radius:12px;overflow:hidden;">
        <iframe src="https://app.smartemailing.cz/public/web-forms-v2/display-form/682388-qazca27se2baurgtm47wyvd504oypoebg76fu7dyk0de1s01cu3hvrfv07ny621bc8dhbnycrh0fpmedmuxcml5b53l7t2dxduph"
          width="100%" height="500" frameborder="0" scrolling="auto"
          style="display:block;border:none;border-radius:12px;background:transparent;">
        </iframe>
      </div>
    </div>

  </div>
</div>
