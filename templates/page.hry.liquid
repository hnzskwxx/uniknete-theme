<style>
.un-hry {
  padding-top: 80px;
  min-height: 100vh;
}

.un-hry-wrap {
  max-width: 1300px;
  margin: 0 auto;
  padding: 48px 32px 64px;
}

/* ASYMETRICKÝ GRID */
.un-hry-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-rows: auto auto;
  gap: 28px;
}

/* Řádek 1: velká karta + malá */
.un-hry-card:nth-child(1) { grid-column: 1; grid-row: 1; }
.un-hry-card:nth-child(2) { grid-column: 2; grid-row: 1; }

/* Řádek 2: 3 stejné karty */
.un-hry-row2 {
  grid-column: 1 / 3;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 28px;
}

/* KARTA */
.un-hry-card {
  background: rgba(8, 11, 8, 0.62);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 1px 0 rgba(255,255,255,0.05) inset;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s;
  cursor: pointer;
}
.un-hry-card:hover {
  transform: scale(1.025);
  background: rgba(8, 11, 8, 0.78);
  box-shadow: 0 16px 48px rgba(0,0,0,0.55), 0 1px 0 rgba(255,255,255,0.07) inset;
}

/* OBRÁZEK — čtverec, žádné ořezání */
.un-hry-card-img {
  aspect-ratio: 1 / 1;
  padding: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  flex-shrink: 0;
}
.un-hry-card-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  border-radius: 8px;
}
.un-hry-card-img-placeholder {
  font-size: 64px;
  opacity: 0.2;
}

/* TEXT */
.un-hry-card-body {
  padding: 20px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.un-hry-card-num {
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 600;
}
.un-hry-card-name {
  font-family: 'Syne', sans-serif;
  font-size: clamp(16px, 1.6vw, 22px);
  font-weight: 800;
  color: var(--white);
  line-height: 1.15;
  letter-spacing: -0.3px;
}
.un-hry-card-desc {
  font-size: 13px;
  color: rgba(240,237,232,0.55);
  font-weight: 300;
  line-height: 1.6;
  flex: 1;
}
.un-hry-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 14px;
  border-top: 1px solid rgba(255,255,255,0.07);
  margin-top: 8px;
}
.un-hry-card-price {
  font-family: 'Syne', sans-serif;
  font-size: 18px;
  font-weight: 800;
  color: var(--white);
}
.un-hry-card-btn {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #fff;
  background: var(--accent);
  padding: 8px 16px;
  border-radius: 6px;
  transition: background 0.2s;
}
.un-hry-card:hover .un-hry-card-btn { background: #ff824d; }

/* Velká karta — větší název */
.un-hry-card:nth-child(1) .un-hry-card-name { font-size: clamp(20px, 2.2vw, 30px); }
.un-hry-card:nth-child(1) .un-hry-card-desc { font-size: 14px; }
.un-hry-card:nth-child(1) .un-hry-card-price { font-size: 22px; }

/* TABLET */
@media (max-width: 1024px) {
  .un-hry-grid { grid-template-columns: 1fr 1fr; }
  .un-hry-card:nth-child(1) { grid-column: 1 / 3; }
  .un-hry-row2 { grid-template-columns: 1fr 1fr; }
}

/* MOBILE */
@media (max-width: 600px) {
  .un-hry-wrap { padding: 32px 16px 48px; }
  .un-hry-grid { grid-template-columns: 1fr; }
  .un-hry-card:nth-child(1) { grid-column: 1; }
  .un-hry-row2 { grid-template-columns: 1fr; }
}
</style>

<div class="un-hry">
  <div class="un-hry-wrap">
    {% assign products = collections.all.products %}

    <div class="un-hry-grid">
      <!-- Karta 1 (velká) -->
      {% assign p = products[0] %}
      <a href="{{ p.url }}" class="un-hry-card">
        <div class="un-hry-card-img">
          {% if p.featured_image %}
            <img src="{{ p.featured_image | img_url: '600x600' }}" alt="{{ p.title | escape }}" loading="eager" />
          {% else %}
            <div class="un-hry-card-img-placeholder">🗺</div>
          {% endif %}
        </div>
        <div class="un-hry-card-body">
          <span class="un-hry-card-num">01 — {{ p.type | default: 'Hra' }}</span>
          <div class="un-hry-card-name">{{ p.title }}</div>
          {% if p.description != blank %}
            <div class="un-hry-card-desc">{{ p.description | strip_html | truncate: 120 }}</div>
          {% endif %}
          <div class="un-hry-card-footer">
            <div class="un-hry-card-price">{% if p.price > 0 %}{{ p.price | money }}{% else %}Na vyžádání{% endif %}</div>
            <span class="un-hry-card-btn">Koupit →</span>
          </div>
        </div>
      </a>

      <!-- Karta 2 (malá) -->
      {% assign p = products[1] %}
      <a href="{{ p.url }}" class="un-hry-card">
        <div class="un-hry-card-img">
          {% if p.featured_image %}
            <img src="{{ p.featured_image | img_url: '400x400' }}" alt="{{ p.title | escape }}" loading="lazy" />
          {% else %}
            <div class="un-hry-card-img-placeholder">🗺</div>
          {% endif %}
        </div>
        <div class="un-hry-card-body">
          <span class="un-hry-card-num">02 — {{ p.type | default: 'Hra' }}</span>
          <div class="un-hry-card-name">{{ p.title }}</div>
          {% if p.description != blank %}
            <div class="un-hry-card-desc">{{ p.description | strip_html | truncate: 80 }}</div>
          {% endif %}
          <div class="un-hry-card-footer">
            <div class="un-hry-card-price">{% if p.price > 0 %}{{ p.price | money }}{% else %}Na vyžádání{% endif %}</div>
            <span class="un-hry-card-btn">Koupit →</span>
          </div>
        </div>
      </a>

      <!-- Řádek 2: karty 3, 4, 5 -->
      <div class="un-hry-row2">
        {% for i in (2..4) %}
          {% assign p = products[i] %}
          {% if p %}
            <a href="{{ p.url }}" class="un-hry-card">
              <div class="un-hry-card-img">
                {% if p.featured_image %}
                  <img src="{{ p.featured_image | img_url: '400x400' }}" alt="{{ p.title | escape }}" loading="lazy" />
                {% else %}
                  <div class="un-hry-card-img-placeholder">🗺</div>
                {% endif %}
              </div>
              <div class="un-hry-card-body">
                <span class="un-hry-card-num">0{{ i | plus: 1 }} — {{ p.type | default: 'Hra' }}</span>
                <div class="un-hry-card-name">{{ p.title }}</div>
                {% if p.description != blank %}
                  <div class="un-hry-card-desc">{{ p.description | strip_html | truncate: 80 }}</div>
                {% endif %}
                <div class="un-hry-card-footer">
                  <div class="un-hry-card-price">{% if p.price > 0 %}{{ p.price | money }}{% else %}Na vyžádání{% endif %}</div>
                  <span class="un-hry-card-btn">Koupit →</span>
                </div>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>
