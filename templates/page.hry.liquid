<style>
.un-hry { padding-top: 80px; }

.un-hry-hero {
  padding: 64px 48px 48px;
  border-bottom: 1px solid var(--white-10);
  background: rgba(8,11,8,0.55);
  backdrop-filter: blur(4px);
}
.un-hry-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 800; color: var(--white);
  line-height: 1.0; letter-spacing: -2px; margin-bottom: 12px;
}
.un-hry-title span { color: var(--accent); }
.un-hry-sub { font-size: 16px; color: var(--white-60); font-weight: 300; }

/* GRID 2 stĺpce */
.un-hry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--white-10);
}

.un-hry-card {
  display: block;
  text-decoration: none;
  color: inherit;
  background: rgba(8,11,8,0.5);
  backdrop-filter: blur(4px);
  overflow: hidden;
  position: relative;
  transition: background 0.3s;
}
.un-hry-card:hover { background: rgba(8,11,8,0.7); }

.un-hry-card-img {
  width: 100%;
  aspect-ratio: 16/10;
  object-fit: cover;
  display: block;
  filter: brightness(0.85) saturate(0.85);
  transition: transform 0.6s ease, filter 0.4s;
}
.un-hry-card:hover .un-hry-card-img {
  transform: scale(1.04);
  filter: brightness(1) saturate(1);
}
.un-hry-card-img-placeholder {
  width: 100%; aspect-ratio: 16/10;
  background: rgba(8,11,8,0.6);
  display: flex; align-items: center;
  justify-content: center; font-size: 48px; opacity: 0.2;
}

.un-hry-card-body {
  padding: 28px 32px 32px;
}
.un-hry-card-num {
  font-size: 10px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent);
  font-weight: 600; margin-bottom: 10px; display: block;
}
.un-hry-card-name {
  font-family: 'Syne', sans-serif;
  font-size: 24px; font-weight: 800;
  color: var(--white); line-height: 1.1;
  letter-spacing: -0.5px; margin-bottom: 10px;
}
.un-hry-card-hook {
  font-size: 14px; color: var(--white-60);
  font-weight: 300; line-height: 1.6; margin-bottom: 20px;
}
.un-hry-card-footer {
  display: flex; justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--white-10);
  padding-top: 16px;
}
.un-hry-card-meta {
  display: flex; gap: 16px; font-size: 12px; color: var(--white-30);
}
.un-hry-card-btn {
  font-size: 11px; font-weight: 600;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--accent); display: flex;
  align-items: center; gap: 6px; transition: gap 0.2s;
}
.un-hry-card:hover .un-hry-card-btn { gap: 10px; }

@media (max-width: 768px) {
  .un-hry-hero { padding: 48px 24px 36px; }
  .un-hry-grid { grid-template-columns: 1fr; }
}
</style>

<div class="un-hry">
  <div class="un-hry-hero">
    <span class="section-label">Katalog her</span>
    <h1 class="un-hry-title">Vyber svůj <span>příběh</span></h1>
    <p class="un-hry-sub">Každá hra je jiný svět. Koupíš voucher, dostaneš instrukce e-mailem.</p>
  </div>

  <div class="un-hry-grid">
    {% for product in collections.all.products %}
      <a href="{{ product.url }}" class="un-hry-card">
        {% if product.featured_image %}
          <img class="un-hry-card-img"
            src="{{ product.featured_image | img_url: '800x500', crop: 'center' }}"
            alt="{{ product.title | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" />
        {% else %}
          <div class="un-hry-card-img-placeholder">🗺</div>
        {% endif %}
        <div class="un-hry-card-body">
          <span class="un-hry-card-num">0{{ forloop.index }} — {{ product.type | default: 'Venkovní hra' }}</span>
          <div class="un-hry-card-name">{{ product.title }}</div>
          {% if product.description != blank %}
            <div class="un-hry-card-hook">{{ product.description | strip_html | truncate: 90 }}</div>
          {% endif %}
          <div class="un-hry-card-footer">
            <div class="un-hry-card-meta">
              <span>👥 2–8</span>
              <span>⏱ 90 min</span>
              {% if product.price > 0 %}<span>{{ product.price | money }}</span>{% endif %}
            </div>
            <span class="un-hry-card-btn">Koupit →</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
