<style>
.un-hry {
  padding-top: 80px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.un-hry-hero {
  padding: 28px 48px;
  border-bottom: 1px solid var(--white-10);
  background: rgba(8,11,8,0.65);
  backdrop-filter: blur(6px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}
.un-hry-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(22px, 2.5vw, 36px);
  font-weight: 800; color: var(--white);
  line-height: 1.0; letter-spacing: -1px; margin: 0;
}
.un-hry-title span { color: var(--accent); }
.un-hry-sub { font-size: 13px; color: var(--white-60); font-weight: 300; text-align: right; }

/* GRID */
.un-hry-grid {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 2px;
  background: rgba(255,255,255,0.05);
  height: calc(100vh - 90px);
}

.un-hry-card:nth-child(1) { grid-column: 1; grid-row: 1 / 3; }
.un-hry-card:nth-child(2) { grid-column: 2; grid-row: 1; }
.un-hry-card:nth-child(3) { grid-column: 3; grid-row: 1; }
.un-hry-card:nth-child(4) { grid-column: 2; grid-row: 2; }
.un-hry-card:nth-child(5) { grid-column: 3; grid-row: 2; }

.un-hry-card {
  position: relative;
  display: block;
  text-decoration: none;
  color: inherit;
  overflow: hidden;
}
.un-hry-card img {
  position: absolute;
  inset: 0; width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(0.8) saturate(0.8);
  transition: transform 0.6s ease, filter 0.4s;
}
.un-hry-card:hover img {
  transform: scale(1.05);
  filter: brightness(0.4) saturate(0.9);
}
.un-hry-card-placeholder {
  position: absolute; inset: 0;
  background: rgba(8,11,8,0.5);
  display: flex; align-items: center;
  justify-content: center; font-size: 48px;
}
.un-hry-card-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(8,11,8,0.96) 0%, rgba(8,11,8,0.3) 50%, transparent 100%);
  transition: background 0.4s;
}
.un-hry-card:hover .un-hry-card-overlay {
  background: linear-gradient(to top, rgba(8,11,8,0.98) 0%, rgba(8,11,8,0.6) 100%);
}
.un-hry-card-body {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 20px 24px;
  z-index: 2;
}

/* Velká karta */
.un-hry-card:nth-child(1) .un-hry-card-body { padding: 32px 36px; }

.un-hry-card-num {
  font-size: 9px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent);
  font-weight: 600; margin-bottom: 5px; display: block;
}
.un-hry-card-name {
  font-family: 'Syne', sans-serif;
  font-weight: 800; color: var(--white);
  line-height: 1.05; letter-spacing: -0.5px; margin-bottom: 6px;
}
.un-hry-card:nth-child(1) .un-hry-card-name { font-size: clamp(20px, 2.2vw, 32px); }
.un-hry-card:not(:nth-child(1)) .un-hry-card-name { font-size: clamp(14px, 1.4vw, 18px); }

.un-hry-card-desc {
  font-size: 12px; color: var(--white-60);
  font-weight: 300; line-height: 1.5;
  margin-bottom: 12px;
  max-height: 0; overflow: hidden;
  transition: max-height 0.3s ease;
}
.un-hry-card:hover .un-hry-card-desc { max-height: 80px; }
.un-hry-card:nth-child(1) .un-hry-card-desc { max-height: 60px; font-size: 13px; }

.un-hry-card-footer {
  display: flex; justify-content: space-between;
  align-items: center;
  padding-top: 10px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.un-hry-card-price {
  font-family: 'Syne', sans-serif;
  font-weight: 700; color: var(--white);
}
.un-hry-card:nth-child(1) .un-hry-card-price { font-size: 18px; }
.un-hry-card:not(:nth-child(1)) .un-hry-card-price { font-size: 14px; }

.un-hry-card-meta { font-size: 10px; color: var(--white-30); }
.un-hry-card-btn {
  font-size: 10px; font-weight: 600;
  letter-spacing: 1px; text-transform: uppercase;
  color: #fff; background: var(--accent);
  padding: 7px 14px; border-radius: 2px;
  opacity: 0; transform: translateY(4px);
  transition: all 0.25s;
}
.un-hry-card:hover .un-hry-card-btn { opacity: 1; transform: translateY(0); }
.un-hry-card:nth-child(1) .un-hry-card-btn { opacity: 1; transform: none; }

@media (max-width: 768px) {
  .un-hry-hero { padding: 20px 24px; }
  .un-hry-grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    height: auto; flex: none;
  }
  .un-hry-card:nth-child(1) { grid-column: 1 / 3; grid-row: auto; min-height: 260px; }
  .un-hry-card:nth-child(n+2) { grid-column: auto; grid-row: auto; min-height: 200px; }
  .un-hry-card-desc { max-height: 60px; }
}
</style>

<div class="un-hry">
  <div class="un-hry-hero">
    <div>
      <span class="section-label" style="margin-bottom:2px;">Katalog her</span>
      <h1 class="un-hry-title">Vyber svůj <span>příběh</span></h1>
    </div>
    <p class="un-hry-sub">Koupíš voucher,<br>dostaneš instrukce e-mailem.</p>
  </div>

  <div class="un-hry-grid">
    {% for product in collections.all.products limit: 5 %}
      <a href="{{ product.url }}" class="un-hry-card">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | img_url: '800x800', crop: 'center' }}"
            alt="{{ product.title | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" />
        {% else %}
          <div class="un-hry-card-placeholder">🗺</div>
        {% endif %}
        <div class="un-hry-card-overlay"></div>
        <div class="un-hry-card-body">
          <span class="un-hry-card-num">0{{ forloop.index }} — {{ product.type | default: 'Hra' }}</span>
          <div class="un-hry-card-name">{{ product.title }}</div>
          {% if product.description != blank %}
            <div class="un-hry-card-desc">{{ product.description | strip_html | truncate: 100 }}</div>
          {% endif %}
          <div class="un-hry-card-footer">
            <div>
              <div class="un-hry-card-price">
                {% if product.price > 0 %}{{ product.price | money }}{% else %}Na vyžádání{% endif %}
              </div>
              <div class="un-hry-card-meta">👥 2–8 · ⏱ 90 min</div>
            </div>
            <span class="un-hry-card-btn">Koupit →</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
