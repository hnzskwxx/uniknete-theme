<style>
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: rgba(8,11,8,0.72);
  z-index: -1;
  pointer-events: none;
}

.un-hry {
  padding-top: 80px;
  min-height: 100vh;
  background: var(--black);
}

/* HERO */
.un-hry-hero {
  padding: 80px 48px 64px;
  text-align: center;
  max-width: 700px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.un-hry-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 800;
  color: var(--white);
  line-height: 1.0;
  margin-bottom: 20px;
  letter-spacing: -1px;
}
.un-hry-title span { color: var(--accent); }
.un-hry-sub {
  font-size: 17px;
  color: var(--white-60);
  font-weight: 300;
  line-height: 1.7;
}

/* GRID */
.un-hry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3px;
  padding: 0 3px 3px;
}
.un-hry-card.featured {
  grid-column: 1 / -1;
}

/* KARTA */
.un-hry-card {
  position: relative;
  display: block;
  text-decoration: none;
  color: inherit;
  overflow: hidden;
  background: var(--dark);
  cursor: pointer;
}
.un-hry-card.featured { aspect-ratio: 21/8; }
.un-hry-card:not(.featured) { aspect-ratio: 4/3; }

.un-hry-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.7) saturate(0.75);
  transition: transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.5s;
  position: absolute;
  inset: 0;
}
.un-hry-card:hover .un-hry-card-img {
  transform: scale(1.05);
  filter: brightness(0.5) saturate(0.9);
}

.un-hry-card-placeholder {
  position: absolute;
  inset: 0;
  background: var(--dark-2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56px;
  opacity: 0.2;
}

/* Overlay gradient */
.un-hry-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(8,11,8,0.95) 0%,
    rgba(8,11,8,0.3) 50%,
    transparent 100%
  );
  transition: background 0.4s;
}
.un-hry-card:hover .un-hry-card-overlay {
  background: linear-gradient(
    to top,
    rgba(8,11,8,0.98) 0%,
    rgba(8,11,8,0.6) 60%,
    rgba(8,11,8,0.2) 100%
  );
}

/* Obsah karty */
.un-hry-card-body {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 32px;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.un-hry-card-type {
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 500;
  opacity: 0;
  transform: translateY(6px);
  transition: all 0.3s;
}
.un-hry-card:hover .un-hry-card-type {
  opacity: 1;
  transform: translateY(0);
}
.un-hry-card-name {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  color: var(--white);
  line-height: 1.1;
  letter-spacing: -0.5px;
}
.un-hry-card.featured .un-hry-card-name { font-size: 40px; }
.un-hry-card:not(.featured) .un-hry-card-name { font-size: 24px; }

.un-hry-card-hook {
  font-size: 13px;
  color: var(--white-60);
  font-weight: 300;
  font-style: italic;
  opacity: 0;
  transform: translateY(6px);
  transition: all 0.3s 0.05s;
  max-width: 480px;
}
.un-hry-card:hover .un-hry-card-hook {
  opacity: 1;
  transform: translateY(0);
}

.un-hry-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4px;
  opacity: 0;
  transform: translateY(8px);
  transition: all 0.3s 0.1s;
}
.un-hry-card:hover .un-hry-card-footer {
  opacity: 1;
  transform: translateY(0);
}
.un-hry-card-meta {
  display: flex;
  gap: 16px;
  font-size: 11px;
  color: var(--white-30);
}
.un-hry-card-btn {
  background: var(--accent);
  color: #fff;
  padding: 10px 20px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  border-radius: 2px;
  transition: background 0.2s;
}
.un-hry-card:hover .un-hry-card-btn { background: #ff824d; }

/* Na mobilu vždy viditelné */
@media (max-width: 768px) {
  .un-hry-hero { padding: 60px 24px 48px; }
  .un-hry-grid { grid-template-columns: 1fr; }
  .un-hry-card.featured { grid-column: 1; aspect-ratio: 4/3; }
  .un-hry-card.featured .un-hry-card-name { font-size: 28px; }
  .un-hry-card-type,
  .un-hry-card-hook,
  .un-hry-card-footer { opacity: 1; transform: none; }
}
</style>

<div class="un-hry">
  <div class="un-hry-hero">
    <span class="section-label">Katalog her</span>
    <h1 class="un-hry-title">Vyber svůj<br><span>příběh</span></h1>
    <p class="un-hry-sub">Každá hra je jiný svět. Koupíš voucher, dostaneš instrukce e-mailem a hraješ kdy chceš.</p>
  </div>

  <div class="un-hry-grid">
    {% for product in collections.all.products %}
      <a href="{{ product.url }}"
         class="un-hry-card{% if forloop.first %} featured{% endif %}">

        {% if product.featured_image %}
          <img class="un-hry-card-img"
            src="{{ product.featured_image | img_url: '1400x900', crop: 'center' }}"
            alt="{{ product.title | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" />
        {% else %}
          <div class="un-hry-card-placeholder">🗺</div>
        {% endif %}

        <div class="un-hry-card-overlay"></div>
        <div class="un-hry-card-body">
          <span class="un-hry-card-type">{{ product.type | default: 'Venkovní hra' }}</span>
          <div class="un-hry-card-name">{{ product.title }}</div>
          <div class="un-hry-card-hook">
            {{ product.description | strip_html | truncate: 80 }}
          </div>
          <div class="un-hry-card-footer">
            <div class="un-hry-card-meta">
              <span>👥 2–8 hráčů</span>
              <span>⏱ 90 min</span>
              <span>{{ product.price | money }}</span>
            </div>
            <span class="un-hry-card-btn">Koupit →</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
