<style>
.un-hry { padding-top: 80px; }

.un-hry-hero {
  padding: 48px 48px 40px;
  border-bottom: 1px solid var(--white-10);
}
.un-hry-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(32px, 4vw, 56px);
  font-weight: 800; color: var(--white);
  line-height: 1.0; letter-spacing: -1px; margin-bottom: 8px;
}
.un-hry-title span { color: var(--accent); }
.un-hry-sub { font-size: 15px; color: var(--white-60); font-weight: 300; }

/* SEZNAM */
.un-hry-list { display: flex; flex-direction: column; }

.un-hry-item {
  display: grid;
  grid-template-columns: 400px 1fr;
  border-bottom: 1px solid var(--white-10);
  text-decoration: none;
  color: inherit;
  transition: background 0.25s;
  min-height: 280px;
}
.un-hry-item:hover { background: rgba(8,11,8,0.4); }
.un-hry-item:nth-child(even) { direction: rtl; }
.un-hry-item:nth-child(even) > * { direction: ltr; }

/* ČTVERCOVÝ OBRÁZEK */
.un-hry-item-img {
  width: 400px;
  height: 280px;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}
.un-hry-item-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(0.9) saturate(0.85);
  transition: transform 0.6s ease, filter 0.4s;
}
.un-hry-item:hover .un-hry-item-img img {
  transform: scale(1.04);
  filter: brightness(1) saturate(1);
}
.un-hry-item-img-placeholder {
  width: 100%; height: 100%;
  background: rgba(8,11,8,0.5);
  display: flex; align-items: center;
  justify-content: center; font-size: 56px; opacity: 0.2;
}

/* TEXT */
.un-hry-item-body {
  padding: 36px 48px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 14px;
}
.un-hry-item-num {
  font-size: 10px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent);
  font-weight: 600;
}
.un-hry-item-name {
  font-family: 'Syne', sans-serif;
  font-size: clamp(24px, 2.5vw, 36px);
  font-weight: 800; color: var(--white);
  line-height: 1.05; letter-spacing: -0.5px;
}
.un-hry-item-desc {
  font-size: 14px; color: var(--white-60);
  font-weight: 300; line-height: 1.7;
  max-width: 480px;
}
.un-hry-item-footer {
  display: flex; align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid var(--white-10);
  margin-top: 4px;
}
.un-hry-item-price {
  font-family: 'Syne', sans-serif;
  font-size: 22px; font-weight: 800;
  color: var(--white);
}
.un-hry-item-meta {
  font-size: 12px; color: var(--white-30);
  display: flex; gap: 16px;
}
.un-hry-item-btn {
  background: var(--accent); color: #fff;
  padding: 12px 24px; font-size: 11px;
  font-weight: 600; letter-spacing: 1.5px;
  text-transform: uppercase; border-radius: 2px;
  transition: background 0.2s;
  white-space: nowrap;
}
.un-hry-item:hover .un-hry-item-btn { background: #ff824d; }

@media (max-width: 900px) {
  .un-hry-hero { padding: 40px 24px 32px; }
  .un-hry-item { grid-template-columns: 1fr; direction: ltr !important; min-height: auto; }
  .un-hry-item-img { width: 100%; height: 260px; }
  .un-hry-item-body { padding: 28px 24px; }
  .un-hry-item-footer { flex-wrap: wrap; gap: 12px; }
}
</style>

<div class="un-hry">
  <div class="un-hry-hero">
    <span class="section-label">Katalog her</span>
    <h1 class="un-hry-title">Vyber svůj <span>příběh</span></h1>
    <p class="un-hry-sub">Každá hra je jiný svět. Koupíš voucher, dostaneš instrukce e-mailem.</p>
  </div>

  <div class="un-hry-list">
    {% for product in collections.all.products %}
      <a href="{{ product.url }}" class="un-hry-item">

        <div class="un-hry-item-img">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
              alt="{{ product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" />
          {% else %}
            <div class="un-hry-item-img-placeholder">🗺</div>
          {% endif %}
        </div>

        <div class="un-hry-item-body">
          <div class="un-hry-item-num">0{{ forloop.index }} — {{ product.type | default: 'Venkovní hra' }}</div>
          <div class="un-hry-item-name">{{ product.title }}</div>
          {% if product.description != blank %}
            <div class="un-hry-item-desc">{{ product.description | strip_html | truncate: 160 }}</div>
          {% endif %}
          <div class="un-hry-item-footer">
            <div>
              <div class="un-hry-item-price">
                {% if product.price > 0 %}{{ product.price | money }}{% else %}Cena na vyžádání{% endif %}
              </div>
              <div class="un-hry-item-meta">
                <span>👥 2–8 hráčů</span>
                <span>⏱ 90 min</span>
              </div>
            </div>
            <span class="un-hry-item-btn">Koupit →</span>
          </div>
        </div>

      </a>
    {% endfor %}
  </div>
</div>
