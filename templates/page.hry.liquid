<style>
.un-hry {
  background: #0D110D;
  min-height: 100vh;
  padding-top: 80px;
}

/* HERO */
.un-hry-hero {
  padding: 72px 48px 56px;
  border-bottom: 1px solid var(--white-10);
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 32px;
  flex-wrap: wrap;
}
.un-hry-hero-left {}
.un-hry-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 800;
  color: var(--white);
  line-height: 1.0;
  letter-spacing: -1px;
  margin-bottom: 12px;
}
.un-hry-title span { color: var(--accent); }
.un-hry-sub {
  font-size: 15px;
  color: var(--white-60);
  font-weight: 300;
  line-height: 1.7;
  max-width: 480px;
}
.un-hry-count {
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--white-30);
  letter-spacing: 1px;
  text-transform: uppercase;
  white-space: nowrap;
}

/* GRID */
.un-hry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--white-10);
}

/* KARTA */
.un-hry-card {
  background: #111411;
  display: block;
  text-decoration: none;
  color: inherit;
  transition: background 0.25s;
  position: relative;
  overflow: hidden;
}
.un-hry-card:hover { background: #161c16; }

/* Fotka */
.un-hry-card-img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/2;
}
.un-hry-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.85) saturate(0.8);
  transition: transform 0.6s ease, filter 0.4s;
}
.un-hry-card:hover .un-hry-card-img {
  transform: scale(1.05);
  filter: brightness(1) saturate(1);
}
.un-hry-card-img-placeholder {
  aspect-ratio: 3/2;
  background: #1a201a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  opacity: 0.3;
}

/* Oranžový pruh nahoře na hover */
.un-hry-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s;
  z-index: 2;
}
.un-hry-card:hover::before { transform: scaleX(1); }

/* Obsah pod fotkou */
.un-hry-card-body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.un-hry-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}
.un-hry-card-name {
  font-family: 'Syne', sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
}
.un-hry-card-price {
  font-size: 16px;
  font-weight: 600;
  color: var(--accent);
  white-space: nowrap;
}
.un-hry-card-desc {
  font-size: 13px;
  color: var(--white-60);
  line-height: 1.6;
  font-weight: 300;
}
.un-hry-card-meta {
  display: flex;
  gap: 16px;
  font-size: 11px;
  color: var(--white-30);
  padding-top: 10px;
  border-top: 1px solid var(--white-10);
  flex-wrap: wrap;
}
.un-hry-card-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4px;
}
.un-hry-card-btn {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 6px;
  transition: gap 0.2s;
}
.un-hry-card:hover .un-hry-card-btn { gap: 10px; }

@media (max-width: 900px) {
  .un-hry-hero { padding: 56px 24px 40px; }
  .un-hry-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .un-hry-grid { grid-template-columns: 1fr; }
}
</style>

<div class="un-hry">
  <div class="un-hry-hero">
    <div class="un-hry-hero-left">
      <span class="section-label">Katalog her</span>
      <h1 class="un-hry-title">Vyber svůj<br><span>příběh</span></h1>
      <p class="un-hry-sub">Koupíš voucher, dostaneš instrukce e-mailem a hraješ kdy chceš.</p>
    </div>
    <div class="un-hry-count">{{ collections.all.products_count }} her k dispozici</div>
  </div>

  <div class="un-hry-grid">
    {% for product in collections.all.products %}
      <a href="{{ product.url }}" class="un-hry-card">

        <div class="un-hry-card-img-wrap">
          {% if product.featured_image %}
            <img class="un-hry-card-img"
              src="{{ product.featured_image | img_url: '800x533', crop: 'center' }}"
              alt="{{ product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" />
          {% else %}
            <div class="un-hry-card-img-placeholder">🗺</div>
          {% endif %}
        </div>

        <div class="un-hry-card-body">
          <div class="un-hry-card-top">
            <div class="un-hry-card-name">{{ product.title }}</div>
            <div class="un-hry-card-price">{{ product.price | money }}</div>
          </div>
          {% if product.description != blank %}
            <div class="un-hry-card-desc">{{ product.description | strip_html | truncate: 80 }}</div>
          {% endif %}
          <div class="un-hry-card-meta">
            <span>👥 2–8 hráčů</span>
            <span>⏱ 90 min</span>
            {% if product.available %}
              <span style="color:var(--accent);">● Dostupné</span>
            {% endif %}
          </div>
          <div class="un-hry-card-cta">
            <span class="un-hry-card-btn">Koupit voucher →</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
