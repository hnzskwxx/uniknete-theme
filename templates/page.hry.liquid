<style>
.un-hry {
  padding-top: 80px;
  min-height: 100vh;
}
.un-hry-hero {
  padding: 80px 64px 64px;
  text-align: center;
}
.un-hry-title {
  font-family: 'Playfair Display', serif;
  font-size: 72px;
  font-weight: 900;
  color: var(--cream);
  line-height: 1.0;
  margin-bottom: 20px;
}
.un-hry-title em { color: var(--gold); font-style: italic; }
.un-hry-sub {
  font-size: 16px;
  color: var(--cream-60);
  font-weight: 300;
  max-width: 480px;
  margin: 0 auto;
  line-height: 1.75;
}

.un-hry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3px;
  padding: 0 3px 3px;
  background: rgba(10,15,8,0.5);
}

/* Velká karta - první hra přes 2 sloupce */
.un-hry-card {
  position: relative;
  display: block;
  text-decoration: none;
  color: inherit;
  overflow: hidden;
  aspect-ratio: 4/3;
  background: rgba(10,15,8,0.8);
}
.un-hry-card.featured {
  grid-column: span 2;
  aspect-ratio: 16/9;
}
.un-hry-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease, filter 0.4s ease;
  filter: brightness(0.7) saturate(0.8);
}
.un-hry-card:hover img {
  transform: scale(1.04);
  filter: brightness(0.85) saturate(1);
}
.un-hry-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(10,15,8,0.9) 0%,
    rgba(10,15,8,0.3) 50%,
    transparent 100%
  );
  transition: opacity 0.3s;
}
.un-hry-card:hover .un-hry-card-overlay {
  background: linear-gradient(
    to top,
    rgba(10,15,8,0.95) 0%,
    rgba(10,15,8,0.4) 60%,
    rgba(10,15,8,0.1) 100%
  );
}
.un-hry-card-body {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 32px;
  z-index: 2;
}
.un-hry-card-tag {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 10px;
  display: block;
  opacity: 0;
  transform: translateY(8px);
  transition: all 0.3s;
}
.un-hry-card:hover .un-hry-card-tag {
  opacity: 1;
  transform: translateY(0);
}
.un-hry-card-name {
  font-family: 'Playfair Display', serif;
  font-weight: 700;
  color: var(--cream);
  line-height: 1.15;
  margin-bottom: 16px;
}
.un-hry-card.featured .un-hry-card-name { font-size: 36px; }
.un-hry-card:not(.featured) .un-hry-card-name { font-size: 24px; }

.un-hry-card-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  opacity: 0;
  transform: translateY(8px);
  transition: all 0.3s 0.05s;
}
.un-hry-card:hover .un-hry-card-cta {
  opacity: 1;
  transform: translateY(0);
}
.un-hry-card-cta::after {
  content: '→';
  transition: transform 0.2s;
}
.un-hry-card:hover .un-hry-card-cta::after { transform: translateX(4px); }

/* Placeholder když není fotka */
.un-hry-card-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, rgba(212,168,71,0.05), rgba(10,15,8,0.8));
  display: flex;
  align-items: center;
  justify-content: center;
}
.un-hry-card-placeholder svg { width: 48px; height: 48px; fill: rgba(212,168,71,0.2); }

@media (max-width: 900px) {
  .un-hry-hero { padding: 60px 24px 48px; }
  .un-hry-title { font-size: 44px; }
  .un-hry-grid { grid-template-columns: 1fr; }
  .un-hry-card.featured { grid-column: span 1; aspect-ratio: 4/3; }
  .un-hry-card.featured .un-hry-card-name { font-size: 26px; }
  .un-hry-card-tag, .un-hry-card-cta { opacity: 1; transform: none; }
}
</style>

<div class="un-hry">
  <div class="un-hry-hero" style="background: rgba(10,15,8,0.6); backdrop-filter: blur(8px);">
    <span class="section-label">Všechny hry</span>
    <h1 class="un-hry-title">Vyber si<br><em>výzvu</em></h1>
    <p class="un-hry-sub">Venkovní únikovky a bojovky v reálných lokacích. Voucher dostaneš e-mailem ihned po platbě.</p>
  </div>

  <div class="un-hry-grid">
    {% assign products = collections.all.products %}
    {% for product in products %}
      <a href="{{ product.url }}"
         class="un-hry-card {% if forloop.first %}featured{% endif %}">

        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | img_url: '1200x900', crop: 'center' }}"
            alt="{{ product.title | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          />
        {% else %}
          <div class="un-hry-card-placeholder">
            <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
        {% endif %}

        <div class="un-hry-card-overlay"></div>
        <div class="un-hry-card-body">
          <span class="un-hry-card-tag">{{ product.type | default: 'Venkovní hra' }}</span>
          <div class="un-hry-card-name">{{ product.title }}</div>
          <span class="un-hry-card-cta">Koupit voucher</span>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
