<style>
.un-product { padding-top: 80px; }
.un-product-hero {
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: calc(100vh - 80px);
}
.un-product-img { position: relative; overflow: hidden; background: rgba(13,17,13,0.6); }
.un-product-img img {
  width: 100%; height: 100%; object-fit: cover;
  filter: brightness(0.9) saturate(0.9);
}
.un-product-img-placeholder {
  width: 100%; height: 100%; min-height: 500px;
  background: rgba(13,17,13,0.6); display: flex;
  align-items: center; justify-content: center;
  font-size: 80px; opacity: 0.1;
}
.un-product-body {
  padding: 64px 56px; display: flex; flex-direction: column;
  justify-content: center; gap: 24px;
  background: transparent; border-left: 1px solid var(--white-10);
}
.un-product-type {
  font-size: 10px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent); font-weight: 500;
}
.un-product-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(32px, 4vw, 48px); font-weight: 800;
  color: var(--white); line-height: 1.05; letter-spacing: -1px;
}
.un-product-meta {
  display: flex; gap: 28px; flex-wrap: wrap;
  padding: 20px 0; border-top: 1px solid var(--white-10);
  border-bottom: 1px solid var(--white-10);
}
.un-product-meta-item { display: flex; flex-direction: column; gap: 3px; }
.un-product-meta-label {
  font-size: 9px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--white-30);
}
.un-product-meta-value { font-size: 14px; font-weight: 500; color: var(--white); }
.un-product-desc {
  font-size: 15px; color: var(--white-60);
  line-height: 1.8; font-weight: 300;
}
.un-product-price {
  font-family: 'Syne', sans-serif;
  font-size: 40px; font-weight: 800; color: var(--white);
}
.un-product-price-old {
  font-size: 20px; color: var(--white-30); text-decoration: line-through; margin-left: 12px;
}
.un-product-qty {
  display: flex; align-items: center; gap: 12px;
}
.un-product-qty label {
  font-size: 10px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--white-30);
}
.un-product-qty input {
  width: 64px; padding: 10px; background: var(--white-06);
  border: 1px solid var(--white-10); border-radius: 2px;
  color: var(--white); font-size: 15px;
  font-family: 'Inter', sans-serif; text-align: center; outline: none;
  transition: border-color 0.2s;
}
.un-product-qty input:focus { border-color: var(--accent); }
.un-product-submit {
  background: var(--accent); color: #fff; border: none;
  padding: 18px 40px; font-size: 12px; font-weight: 600;
  cursor: pointer; font-family: 'Inter', sans-serif;
  letter-spacing: 2px; text-transform: uppercase;
  transition: background 0.2s; border-radius: 2px; width: 100%;
}
.un-product-submit:hover { background: #ff824d; }
.un-product-submit:disabled { opacity: 0.3; cursor: not-allowed; }
.un-product-note {
  font-size: 12px; color: var(--white-30);
  display: flex; align-items: center; gap: 8px;
}
.un-product-note::before { content: '—'; color: var(--accent); }

@media (max-width: 900px) {
  .un-product-hero { grid-template-columns: 1fr; }
  .un-product-img { min-height: 320px; }
  .un-product-body { padding: 40px 24px; border-left: none; border-top: 1px solid var(--white-10); }
}
</style>

<div class="un-product">
  <div class="un-product-hero">
    <div class="un-product-img">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '1000x1000', crop: 'center' }}"
          alt="{{ product.featured_image.alt | escape }}" loading="eager" />
      {% else %}
        <div class="un-product-img-placeholder">🗺</div>
      {% endif %}
    </div>
    <div class="un-product-body">
      <div class="un-product-type">{{ product.type | default: 'Venkovní hra' }}</div>
      <h1 class="un-product-title">{{ product.title }}</h1>
      <div class="un-product-meta">
        <div class="un-product-meta-item">
          <span class="un-product-meta-label">Hráči</span>
          <span class="un-product-meta-value">2–8 osob</span>
        </div>
        <div class="un-product-meta-item">
          <span class="un-product-meta-label">Délka</span>
          <span class="un-product-meta-value">60–120 min</span>
        </div>
        <div class="un-product-meta-item">
          <span class="un-product-meta-label">Platnost</span>
          <span class="un-product-meta-value">12 měsíců</span>
        </div>
        <div class="un-product-meta-item">
          <span class="un-product-meta-label">Doručení</span>
          <span class="un-product-meta-value">E-mailem</span>
        </div>
      </div>
      <div class="un-product-desc">{{ product.description }}</div>
      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
        <div>
          <span class="un-product-price">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="un-product-price-old">{{ product.compare_at_price | money }}</span>
          {% endif %}
        </div>
        <div class="un-product-qty">
          <label>Počet</label>
          <input type="number" name="quantity" value="1" min="1" max="20" />
        </div>
        {% if product.available %}
          <button type="submit" class="un-product-submit">Přidat do košíku</button>
        {% else %}
          <button class="un-product-submit" disabled>Vyprodáno</button>
        {% endif %}
        <p class="un-product-note">Voucher přijde e-mailem ihned po zaplacení</p>
        <p class="un-product-note">Platnost 12 měsíců, termín si vybereš sám</p>
      {% endform %}
    </div>
  </div>
</div>
