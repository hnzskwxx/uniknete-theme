<style>
.un-reviews-section {
  padding: 88px 48px;
  background: var(--dark-2);
  border-top: 1px solid var(--cream-08);
}
.un-reviews-header { margin-bottom: 48px; }
.un-reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.un-review-card {
  background: var(--dark);
  border: 1px solid var(--cream-08);
  border-radius: 8px;
  padding: 28px;
}
.un-stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; margin-bottom: 14px; }
.un-review-text {
  font-size: 14px;
  color: var(--cream-60);
  line-height: 1.7;
  font-weight: 300;
  margin-bottom: 18px;
  font-style: italic;
}
.un-review-author {
  font-size: 12px;
  font-weight: 500;
  color: var(--cream-40);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
@media (max-width: 900px) {
  .un-reviews-section { padding: 56px 24px; }
  .un-reviews-grid { grid-template-columns: 1fr; }
}
</style>

<section class="un-reviews-section" id="recenze">
  <div class="un-reviews-header">
    <span class="section-label">{{ section.settings.label }}</span>
    <h2 class="section-title">{{ section.settings.title }}</h2>
  </div>
  <div class="un-reviews-grid">
    {% for block in section.blocks %}
      <div class="un-review-card" {{ block.shopify_attributes }}>
        <div class="un-stars">★★★★★</div>
        <p class="un-review-text">"{{ block.settings.text }}"</p>
        <div class="un-review-author">{{ block.settings.author }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Recenze",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Recenze" },
    { "type": "text", "id": "title", "label": "Nadpis", "default": "Co říkají hráči" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Recenze",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Text recenze" },
        { "type": "text", "id": "author", "label": "Autor" }
      ]
    }
  ],
  "presets": [{
    "name": "Recenze",
    "blocks": [
      { "type": "review", "settings": { "text": "Naprosto skvělý zážitek! Strávili jsme s rodinou skoro 2 hodiny hledáním stop.", "author": "Markéta H. · Děčín" } },
      { "type": "review", "settings": { "text": "Perfektní teambuilding! Kolektiv se skvěle sehrál, hry jsou vymyšlené s citem.", "author": "Tomáš B. · Praha" } },
      { "type": "review", "settings": { "text": "Papírovou verzi jsme hráli na chalupě — geniální nápad. Bavily se i děti.", "author": "Jana K. · Liberec" } }
    ]
  }]
}
{% endschema %}
