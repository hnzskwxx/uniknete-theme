<style>
.un-footer {
  padding: 40px 48px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--cream-08);
  flex-wrap: wrap;
  gap: 16px;
  background: var(--dark-3);
}
.un-footer-logo {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
}
.un-footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
.un-footer-links a {
  font-size: 13px;
  color: var(--cream-40);
  text-decoration: none;
  transition: color 0.2s;
}
.un-footer-links a:hover { color: var(--gold); }
.un-footer-copy { font-size: 12px; color: var(--cream-20); }

@media (max-width: 768px) {
  .un-footer { padding: 32px 24px; flex-direction: column; align-items: flex-start; }
}
</style>

<footer class="un-footer">
  <a href="/" class="un-footer-logo">{{ section.settings.logo_text }}</a>

  <div class="un-footer-links">
    {% for link in linklists[section.settings.footer_menu].links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
    <a href="{{ shop.url }}/policies/privacy-policy">Ochrana osobních údajů</a>
    <a href="{{ shop.url }}/policies/refund-policy">Reklamace</a>
  </div>

  <div class="un-footer-copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}</div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Unikněte!"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
